---
import Layout from '../layouts/Layout.astro';

const links = [
	{ label: 'github', href: 'https://github.com/shujanshaikh' },
	{ label: 'x', href: 'https://x.com/shujanshaikh' },
	{ label: 'email', href: 'mailto:shaikhshujan@gmail.com' },
];

const externalAttrs = (href: string) =>
	href.startsWith('mailto:') ? {} : { target: '_blank', rel: 'noopener noreferrer' };
---

<Layout>
	<div class="relative flex min-h-dvh w-full flex-col" style="background-color: var(--bg); color: var(--fg);">
		<main class="relative z-10 mx-auto flex w-full max-w-lg flex-col px-6 py-10 md:px-8 md:py-14">
			<!-- Header -->
			<header class="reveal flex items-center justify-between pb-6">
				<span class="text-[11px] tracking-[0.15em] uppercase" style="color: var(--fg-muted);">Shujan Shaikh</span>
				<button
					id="theme-toggle"
					class="text-[11px] tracking-[0.08em] uppercase transition-colors duration-200"
					style="color: var(--fg-dim);"
					onmouseenter="this.style.color='var(--primary)'"
					onmouseleave="this.style.color='var(--fg-dim)'"
					aria-label="Toggle theme"
				>
					[ theme ]
				</button>
			</header>

			<!-- Hero -->
			<section class="reveal flex items-center gap-4 py-6">
				<div class="h-14 w-14 shrink-0 overflow-hidden" style="border: 1.5px solid var(--border);">
					<img src="/profile.png" alt="Shujan Shaikh" class="h-full w-full object-cover" loading="eager" decoding="async" />
				</div>
				<div>
					<h1 class="text-[17px] font-semibold tracking-tight">Shujan Shaikh</h1>
					<p class="mt-1 text-[12px]" style="color: var(--fg-muted);">Building software for the fun of it.</p>
				</div>
			</section>

			<!-- Links -->
			<nav aria-label="Primary" class="reveal stagger-1 flex gap-3 pb-8">
				{links.map((link) => (
					<a
						href={link.href}
						class="text-[11px] tracking-[0.06em] uppercase transition-colors duration-200"
						style="color: var(--fg-dim);"
						onmouseenter="this.style.color='var(--primary)'"
						onmouseleave="this.style.color='var(--fg-dim)'"
						{...externalAttrs(link.href)}
					>
						{link.label}
					</a>
				))}
			</nav>

			<!-- Divider -->
			<div class="h-px w-full" style="background-color: var(--border);" />

			<!-- AMA -->
			<section class="py-8">
				<div class="reveal mb-4 flex items-center justify-between">
					<span class="text-[13px] font-semibold">ama</span>
					<div class="flex gap-3">
						<a href="https://ama.shujan.xyz" target="_blank" rel="noopener noreferrer" class="text-[10px] tracking-[0.08em] uppercase transition-colors duration-200" style="color: var(--fg-dim);" onmouseenter="this.style.color='var(--primary)'" onmouseleave="this.style.color='var(--fg-dim)'">live</a>
						<a href="https://github.com/shujanshaikh/ama" target="_blank" rel="noopener noreferrer" class="text-[10px] tracking-[0.08em] uppercase transition-colors duration-200" style="color: var(--fg-dim);" onmouseenter="this.style.color='var(--primary)'" onmouseleave="this.style.color='var(--fg-dim)'">repo</a>
					</div>
				</div>

				<div class="reveal stagger-1">
					<div class="relative w-full overflow-hidden" style="border: 1px solid var(--border); height: 260px;">
						<iframe
							src="https://ama.shujan.xyz"
							title="AMA Preview"
							class="h-full"
							loading="lazy"
							scrolling="no"
							style="background-color: var(--bg); border: none; width: calc(100% + 20px); margin-right: -20px; overflow: hidden;"
						></iframe>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
